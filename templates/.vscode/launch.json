{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Lua Interpreter",
            "type": "lua-local",
            "request": "launch",
            "program": {
                "lua": "lua",
                "file": "${file}"
            }
        },
        {
            "name": "Debug Busted",
            "type": "lua-local",
            "request": "launch",
            "program": {
                "command": "busted"
            },
            "stopOnEntry": false,
        },
        {
            "name": "Debug Busted (filter from file)",
            "type": "lua-local",
            "request": "launch",
            "breakInCoroutines": false,
            "program": {
                "command": "pwsh"
            },
            "args": [
                "-NoProfile",
                "tools/busted-filter.ps1"
            ]
        }
    ]
}
